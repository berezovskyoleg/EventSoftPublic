{
  "name": "eventsoft",
  "version": "0.1.0",
  "private": true,
  "description": "EventSoft monorepo — desktop and web apps for events with shared licensing",
  "scripts": {
    "dev:toastmachine": "cd apps/toastmachine && npm run dev",
    "build:toastmachine": "cd apps/toastmachine && npm run tauri:build",
    "dev:toastmachine:tauri": "cd apps/toastmachine && npm run tauri:dev",
    "dev:musicbingo": "cd apps/musicbingo && npm run dev",
    "dev:musicbingo:tauri": "cd apps/musicbingo && npm run tauri:dev",
    "build:musicbingo": "cd apps/musicbingo && npm run tauri:build",
    "dev:license-server": "cd license-server && npm run dev",
    "start:license-server": "cd license-server && npm start",
    "init:license-server": "cd license-server && npm run init"
  },
  "workspaces": [
    "apps/*",
    "license-server"
  ]
}
